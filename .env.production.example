# PostgreSQL Database configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=africhina
DB_HOST=db
DB_PORT=5432

# Node.js Server configuration
PORT=5000
NODE_ENV=production

# Security
JWT_SECRET=your_super_secret_jwt_key_here
CORS_ORIGINS=https://africhinabridge.com,https://admin.africhinabridge.com

# Email configuration (SMTP for production)
EMAIL_USER=your_smtp_email@example.com
EMAIL_PASS=your_smtp_password
EMAIL_HOST=smtp.example.com
EMAIL_PORT=465

# Frontend configuration
VITE_API_BASE_URL=https://api.africhinabridge.com
VITE_TAWKTO_ID=your_tawkto_property_id
